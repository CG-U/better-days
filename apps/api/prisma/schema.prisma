generator client {
  provider = "prisma-client-js"
  // host (macOS) + Docker container (linux arm64/x64, bookworm) share the bind-mounted client
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Display profile. Null until the user sets one in /settings; the UI falls
  // back to the email local-part. avatarColor is a key from AVATAR_COLORS in
  // packages/shared — the avatar is the first letter, never an upload.
  username    String? @unique
  avatarColor String?

  // Recovery profile (set once during dashboard onboarding, editable later)
  recoveryStartDate DateTime? @db.Date
  // Typical daily gambling spend before recovery, in cents — basis for "money saved"
  dailySpendCents   Int?

  urges             Urge[]
  relapses          Relapse[]
  checkIns          CheckIn[]
  copingStrategies  CopingStrategy[]
  journalEntries    JournalEntry[]

  @@map("users")
}

/// Free-form writing, owned entirely by the user. Unlike CheckIn there is no
/// calendar day and no unique constraint: an entry belongs to the moment it was
/// written, and you may write as many in a day as you need. Nothing aggregates
/// it, nothing scores it, and its text never leaves this table.
model JournalEntry {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  body String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@map("journal_entries")
}

/// Something the user knows helps them through a craving, in their own words.
/// Surfaced on the ride-it-out screen; managed from /toolkit.
model CopingStrategy {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label String
  // Times the user tapped "this helped". Sorts the list, so the thing that
  // actually works drifts to the top without them having to curate it.
  helpedCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One entry per phrase — re-adding "call my brother" should not duplicate it.
  @@unique([userId, label])
  @@index([userId])
  @@map("coping_strategies")
}

model CheckIn {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The user's local calendar day (sent by the client as YYYY-MM-DD) — one
  // morning and one evening entry per day; re-saving updates in place.
  date   DateTime @db.Date
  period String // 'morning' | 'evening' (validated by shared Zod schema)

  // Morning fields
  mood         Int? // 1-5 (Down … Calm)
  sleepQuality Int? // 1-10
  stressLevel  Int? // 1-5
  intention    String?

  // Evening fields
  urgesToday Int?
  reflection String?
  gratitude  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date, period])
  @@map("check_ins")
}

model Relapse {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amountSpentCents Int
  trigger          String
  notes            String?
  occurredAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([userId, occurredAt])
  @@map("relapses")
}

model Urge {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  intensity  Int // 1–10, validated by shared Zod schema
  trigger    String
  notes      String?
  // 'unresolved' | 'passed' | 'gambled' (URGE_OUTCOMES in packages/shared).
  // Existing rows backfill to 'unresolved': we cannot know how they ended.
  outcome    String    @default("unresolved")
  resolvedAt DateTime? // when the user told us how it ended
  occurredAt DateTime  @default(now())
  createdAt  DateTime  @default(now())

  @@index([userId, occurredAt])
  @@map("urges")
}

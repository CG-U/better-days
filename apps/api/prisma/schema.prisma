generator client {
  provider = "prisma-client-js"
  // host (macOS) + Docker container (linux arm64/x64, bookworm) share the bind-mounted client
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Recovery profile (set once during dashboard onboarding, editable later)
  recoveryStartDate DateTime? @db.Date
  // Typical daily gambling spend before recovery, in cents — basis for "money saved"
  dailySpendCents   Int?

  urges    Urge[]
  relapses Relapse[]
  checkIns CheckIn[]

  @@map("users")
}

model CheckIn {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The user's local calendar day (sent by the client as YYYY-MM-DD) — one
  // morning and one evening entry per day; re-saving updates in place.
  date   DateTime @db.Date
  period String // 'morning' | 'evening' (validated by shared Zod schema)

  // Morning fields
  mood         Int? // 1-5 (Down … Calm)
  sleepQuality Int? // 1-10
  stressLevel  Int? // 1-5
  intention    String?

  // Evening fields
  urgesToday Int?
  reflection String?
  gratitude  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date, period])
  @@map("check_ins")
}

model Relapse {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amountSpentCents Int
  trigger          String
  notes            String?
  occurredAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([userId, occurredAt])
  @@map("relapses")
}

model Urge {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  intensity  Int // 1–10, validated by shared Zod schema
  trigger    String
  notes      String?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, occurredAt])
  @@map("urges")
}
